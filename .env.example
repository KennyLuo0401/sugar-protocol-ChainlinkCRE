# ========================================
# Sugar Protocol — Environment Variables
# ========================================

# Required: OpenAI API Key for LLM analysis
OPENAI_API_KEY=sk-your-api-key-here

# Optional: Database (auto-configured in Docker, override for local dev)
# DB_URL=sqlite+aiosqlite:///sugar.db
# DB_URL=postgresql+asyncpg://sugar:sugar_pass@localhost:5432/sugar_protocol

# Optional: LLM Settings
DEFAULT_MODEL=gpt-4o-mini
LLM_TIMEOUT=30
LLM_MAX_RETRIES=3

# Optional: Fetcher Settings
FETCH_TIMEOUT=15
JINA_BASE_URL=https://r.jina.ai/

# Optional: Docker Compose Ports
APP_PORT=8000
NGINX_PORT=80

# Optional: Server Settings
WORKERS=1
LOG_LEVEL=info

# Required: EVM (Sepolia Testnet)
EVM_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
EVM_PRIVATE_KEY=<your-deployer-private-key>
RESOLUTION_CONTRACT_ADDRESS=0xCbD2fc2974a121EB373b89B6B9dFa0a1D863e550
PREDICTION_MARKET_ADDRESS=0x8bB67a5c7Ca89Ee759f9f11a216Eb2921e68f7A5
